DATABASE_URL=postgresql://user:pass@host:5432/dbname

# LLM provider — "openrouter" (default, cheap) | "anthropic" | future: "ollama"
LLM_PROVIDER=openrouter
# Model — default: openrouter/qwen/qwen-2.5-72b-instruct (cheap $0.15/1M tokens)
# Alt: claude-haiku-4-5-20251001 (when LLM_PROVIDER=anthropic)
LLM_MODEL=openrouter/qwen/qwen-2.5-72b-instruct

# Required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...

# Alternative: Required when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Job ingestion APIs (optional for MVP — skip if not testing ingestion)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
JOOBLE_API_KEY=your_jooble_api_key

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
# NOT yet configured in Vercel — add before enabling auth in production
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App URL ──────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=https://aimeajob.vercel.app

# ─── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ─── Email Digests ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
CRON_SECRET=secret_token_for_cron_auth
