DATABASE_URL=postgresql://user:pass@host:5432/dbname

# LLM provider — "anthropic" (default) | future: "ollama"
LLM_PROVIDER=anthropic
# Model — default: claude-haiku-3-5-20241022 (fast + cheap for extraction)
# When Mac Studio arrives, switch to: LLM_PROVIDER=ollama + LLM_MODEL=qwen3:7b
LLM_MODEL=claude-haiku-4-5-20251001

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Job ingestion APIs (optional for MVP — skip if not testing ingestion)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
JOOBLE_API_KEY=your_jooble_api_key
